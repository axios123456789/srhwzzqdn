<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xk.srhwzzqdn.manager.assetControlArea.mapper.AssetTransactionMapper">

    <!--  新增资产记账  -->
    <insert id="addAssetTransaction">
        insert into t_asset_transaction (invoice_no,
                                      invoice_action,
                                      record_time,
                                      amount,
                                      asset_ledger_id,
                                      transaction_type,
                                      invoice_type,
                                      spending_type,
                                      income_type,
                                      settlement_status,
                                      invoice_owner,
                                      data_source,
                                      remark,
                                      update_time,
                                      update_by)
        values (#{invoiceNo},
                #{invoiceAction},
                #{recordTime},
                #{amount},
                #{assetLedgerId},
                #{transactionType},
                #{invoiceType},
                #{spendingType},
                #{incomeType},
                #{settlementStatus},
                #{invoiceOwner},
                #{dataSource},
                #{remark},
                now(),
                #{updateBy})
    </insert>

    <!--  修改资产记账  -->
    <update id="updateAssetTransaction">
        update t_asset_transaction
        <set>
            <if test="invoiceNo != null and invoiceNo != ''">
                invoice_no = #{invoiceNo},
            </if>
            <if test="invoiceAction != null and invoiceAction != ''">
                invoice_action = #{invoiceAction},
            </if>
            <if test="recordTime != null">
                record_time = #{recordTime},
            </if>
            <if test="amount != null">
                amount = #{amount},
            </if>
            <if test="assetLedgerId != null">
                asset_ledger_id = #{assetLedgerId},
            </if>
            <if test="transactionType != null">
                transaction_type = #{transactionType},
            </if>
            <if test="invoiceType != null">
                invoice_type = #{invoiceType},
            </if>
            <if test="spendingType != null">
                spending_type = #{spendingType},
            </if>
            <if test="incomeType != null">
                income_type = #{incomeType},
            </if>
            <if test="settlementStatus != null">
                settlement_status = #{settlementStatus},
            </if>
            <if test="invoiceOwner != null and invoiceOwner != ''">
                invoice_owner = #{invoiceOwner},
            </if>
            <if test="dataSource != null">
                data_source = #{dataSource},
            </if>
            <if test="remark != null and remark != ''">
                remark = #{remark},
            </if>
            update_time = now(),
            update_by = #{updateBy}
        </set>
        where id = #{id}
    </update>

    <!--   根据ids批量删除资产记账  -->
    <delete id="deleteAllAssetTransactionByIds">
        delete from t_asset_transaction where id in
        <foreach collection="ids" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
    </delete>
</mapper>
